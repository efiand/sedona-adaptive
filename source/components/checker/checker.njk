<p class="form__checker checker{{ " checker--checkbox" if field.type === "checkbox" }}">
  <input class="visually-hidden" id="{{ field.name }}-{{ loop.index }}" name="{{ field.name }}"
    type="{{ field.type }}"{{ " checked" if field.checked }}>
  <label{{ " class=\"iconable\"" if field.type === "checkbox" }} for="{{ field.name }}-{{ loop.index }}">
    {{ field.label }}
  </label>
</p>
