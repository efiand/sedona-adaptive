<header class="header">
  <button class="header-toggler hidden">
    <span class="visually-hidden">
      {{ data.toggleMenuText }}
    </span>
  </button>

  <nav>
    <a class="header__logo" href="index.html">
      <img src="{{ data.logoSrc }}" alt="{{ data.logoAlt }}">
    </a>
    <ul class="header-nav">
      {% for link in data.menu %}
        <li>
          <a class="header__link" href="{{ link.url }}">
            {{ link.text }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  <img class="header__img" src="{{ data.introImg }}" alt="{{ data.introAlt }}">

  <h1 class="{{ "visually-hidden" if data.isIndex else "header__heading" }}">
    {{ data.siteName if data.isIndex else data.pageTitle }}
  </h1>
</header>
