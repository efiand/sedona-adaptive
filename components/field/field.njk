{% set attrs = "name=\"" + field.name + "\"" + "id=\"" + field.name + "\""
  + " placeholder=\"" + field.placeholder + "\"" %}
{% if field.required %}
  {% set attrs = attrs + " required" %}
{% endif %}

<p class="field {{ "field--" + field.name if field.hasIcon }} {{ classes }}">
  <label class="{{ "visually-hidden" if field.hideLabel else "field__label" }}"
    for="{{ field.name }}">
    {{ field.label }}
  </label>
  {% if field.type === "textarea" %}
    <textarea class="field__input field__input--message" {{ attrs }}></textarea>
  {% else %}
    <input class="field__input" type="{{ field.type }}" {{ attrs }}>
  {% endif %}
</p>
