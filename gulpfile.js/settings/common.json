{
  "template": "source/components/_page/page.njk",
  "tasks": {
    "build": [
      "clean",
      "tmp",
      "symbols",
      "css",
      "scripts",
      "html",
      "img",
      "icons",
      "webp",
      "static"
    ],
    "dev": [
      "build",
      "server"
    ]
  },
  "watchers": [
    [
      ["source/**/*.js"],
      ["scripts"]
    ],
    [
      ["source/**/*.scss"],
      ["css"]
    ],
    [
      ["source/data/**/*.json", "source/**/*.njk"],
      ["html"]
    ],
    [
      "source/img/**/*.{jpg,png}",
      ["img", "webp"]
    ],
    [
      "source/img/**/*.svg",
      ["img"]
    ],
    [
      ["source/img/icons/**/*.svg", "source/**/*.icon.svg"],
      ["icons"]
    ],
    [
      ["source/img/symbols/**/*.svg", "source/**/*.symbol.svg"],
      ["symbols"]
    ],
    [
      "source/static/**/*",
      ["static"]
    ]
  ],
  "dest": "build",
  "lintspaces": {
    "editorconfig": ".editorconfig"
  },
  "rename": {
    "suffix": ".min"
  },
  "server": {
    "server": "build"
  }
}
