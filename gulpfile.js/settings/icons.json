{
  "src": [
    "source/img/icons/**/*.svg",
    "source/**/*.icon.svg"
  ],
  "dest": {
    "icons": "tmp/icons",
    "sprite": "tmp"
  },
  "options": {
    "baseSize": 1,
    "cssFile": "icons.css",
    "padding": 10,
    "preview": {
      "sprite": ""
    },
    "svg": {
      "sprite": "../build/img/icons.svg"
    }
  }
}
